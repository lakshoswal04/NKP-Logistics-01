# NKP Logistics — FastAPI backend environment
# Copy to backend/.env and fill in real values. Every key here is a placeholder;
# with placeholders left empty the app runs fully on mock providers + seed data.

ENVIRONMENT=development
DEBUG=true

DATABASE_URL=postgresql+asyncpg://nkp:nkp@localhost:5432/nkp_logistics
REDIS_URL=redis://localhost:6379/0

# Generate with: openssl rand -hex 32
JWT_SECRET=change-me-in-production
ACCESS_TOKEN_EXPIRE_MINUTES=30
REFRESH_TOKEN_EXPIRE_DAYS=14

CORS_ORIGINS=["http://localhost:5001"]

# --- External providers (stakeholder-supplied; empty = mock implementation) ---
GOOGLE_MAPS_API_KEY=
ANTHROPIC_API_KEY=

# Email: mock | resend | sendgrid
EMAIL_PROVIDER=mock
EMAIL_API_KEY=
EMAIL_FROM=notifications@nkplogistics.example
SALES_NOTIFICATION_EMAIL=sales@nkplogistics.example

# Reserved for later iterations (per PRD):
# RAZORPAY_KEY_ID=
# RAZORPAY_KEY_SECRET=
# WHATSAPP_ACCESS_TOKEN=
# WHATSAPP_PHONE_NUMBER_ID=
# TWILIO_ACCOUNT_SID=
# TWILIO_AUTH_TOKEN=
# AWS_ACCESS_KEY_ID=
# AWS_SECRET_ACCESS_KEY=
# S3_BUCKET=
# SENTRY_DSN=
